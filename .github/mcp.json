{
  "servers": {
    "claude-context": {
      "args": [
        "-y",
        "@zilliz/claude-context-mcp@latest"
      ],
      "command": "npx",
      "env": {
        "EMBEDDING_PROVIDER": "Gemini",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "MILVUS_TOKEN": "${MILVUS_TOKEN}"
      },
      "tools": [
        "*"
      ],
      "type": "local"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "command": "npx",
      "tools": [
        "*"
      ],
      "type": "local"
    },
    "memory": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "command": "npx",
      "tools": [
        "*"
      ],
      "type": "local"
    },
    "ripgrep": {
      "args": [
        "-y",
        "mcp-ripgrep"
      ],
      "command": "npx",
      "tools": [
        "*"
      ],
      "type": "local"
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx",
      "tools": [
        "*"
      ],
      "type": "local"
    }
  }
}
